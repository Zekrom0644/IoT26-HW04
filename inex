<!DOCTYPE html>
<html>
<head>
    <title>RPI GPIO Control</title>
    <style>
        body { font-family: Arial; text-align: center; padding: 40px; background: #f0f0f0; }
        h1 { color: #333; }
        .card { background: white; border-radius: 12px; padding: 30px;
                display: inline-block; margin: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .btn { padding: 12px 28px; font-size: 16px; border: none;
               border-radius: 8px; cursor: pointer; margin: 5px; }
        .on  { background: #4CAF50; color: white; }
        .off { background: #f44336; color: white; }
        .status { font-size: 14px; color: #666; margin-top: 8px; }
    </style>
</head>
<body>
    <h1>🔆 Raspberry Pi LED Control</h1>

    <div class="card">
        <h2>LED 1 (GPIO 23)</h2>
        <a href="/led1/on"><button class="btn on">ON</button></a>
        <a href="/led1/off"><button class="btn off">OFF</button></a>
        <p class="status">Status: <b>{{ "ON" if led1 else "OFF" }}</b></p>
    </div>

    <div class="card">
        <h2>LED 2 (GPIO 24)</h2>
        <a href="/led2/on"><button class="btn on">ON</button></a>
        <a href="/led2/off"><button class="btn off">OFF</button></a>
        <p class="status">Status: <b>{{ "ON" if led2 else "OFF" }}</b></p>
    </div>
</body>
</html>
